{
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [{"source": "/(.*)", "destination": "/index.html"}],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "Permissions-Policy", "value": "camera=self, microphone=()"},
        {"key": "X-Content-Type-Options", "value": "nosniff"}
      ]
    }
  ]
}
